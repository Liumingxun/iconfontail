{
  "name": "iconfontail",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "bun@1.3.13",
  "description": "iconfontail 可以用来集成 iconfont.cn 的图标到 Tailwind CSS 中，并借助 Tree Shaking 优化图标体积。",
  "author": "lime <liumingxun@yeah.net>",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/Liumingxun/iconfontail"
  },
  "keywords": [
    "iconfont",
    "iconfont-cn",
    "tailwindcss",
    "iconfontail"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bunup --watch",
    "build": "bunup",
    "prepublishOnly": "bun run build",
    "lint": "eslint .",
    "release": "bunx bumpp --commit --push --tag"
  },
  "peerDependencies": {
    "tailwindcss": "4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/bun": "latest",
    "bunup": "^0.16.31",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.7.0"
  }
}
